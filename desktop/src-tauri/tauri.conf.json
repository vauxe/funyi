{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Funyi Live Captions",
  "version": "0.1.0",
  "identifier": "local.funyi.desktop",
  "build": {
    "beforeBuildCommand": "pnpm run build:ui",
    "beforeDevCommand": "pnpm run build:ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Funyi Live Captions",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src ws://127.0.0.1:* ws://localhost:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all"
  }
}
