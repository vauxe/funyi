{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Funyi Live Captions",
  "version": "0.1.0",
  "identifier": "local.funyi.desktop",
  "build": {
    "beforeBuildCommand": "node scripts/build-ui.mjs",
    "beforeDevCommand": "node scripts/build-ui.mjs",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Funyi Live Captions",
        "width": 960,
        "height": 180,
        "minWidth": 280,
        "minHeight": 128,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src ws://127.0.0.1:* ws://localhost:*; img-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all"
  }
}
